{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true,
    "jquery": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "semi": ["warn", "always"]
  },
  "ignorePatterns": [
    "node_modules/",
    "wwwroot/",
    "bin/",
    "obj/"
  ]
}
